###############################################
# BitcoinSolar Native Miner
###############################################

# Miner identity
MINER_NAME=blsr-native-miner-01

###############################################
# Orchestrator Integration
###############################################
# URL of your ai-orchestrator service
ORCHESTRATOR_URL=https://orchestrator.bitcoinsolar.org

# Must match BACKEND_NODE_AUTH_KEY in orchestrator .env.local
ORCHESTRATOR_AUTH_KEY=blsr_backend_node_auth_92f1c7e4b9d3a1f0e6c4d8b2


###############################################
# Mining Wallet
###############################################
# Private key used to sign mining submissions
MINER_PRIVATE_KEY=replace-with-your-private-key

# Optional: derived automatically if omitted
MINER_ADDRESS=0xddaAd340b0f1Ef65169Ae5E41A8b10776a75482d

###############################################
# Chain Configuration
###############################################
RPC_BLSR_CHAIN=https://blsr-rpc.bitcoinsolar.org
CHAIN_ID=12345

###############################################
# Miner Performance
###############################################
MINER_THREADS=4
POLL_INTERVAL=3000
LOG_LEVEL=info

###############################################
# Optional GPU Settings
###############################################
# GPU_ENABLED=true
# GPU_PLATFORM=0
# GPU_DEVICE=0
# GPU_WORKSIZE=256
# GPU_LOCAL_WORKSIZE=64
