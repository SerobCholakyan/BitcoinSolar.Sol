###############################################
# BitcoinSolar Native Miner Configuration
###############################################

# RPC endpoint for your BLSR chain node
RPC_BLSR_CHAIN=https://blsr-rpc.bitcoinsolar.org

# Chain ID for BitcoinSolar
CHAIN_ID=12345

# Miner wallet private key (REQUIRED)
# This wallet receives mining rewards
MINER_PRIVATE_KEY=replace-with-your-private-key

# Miner address (optional; auto-derived from private key)
MINER_ADDRESS=replace-with-your-address

# Mining intensity / threads
MINER_THREADS=4

# Polling interval for new work (ms)
POLL_INTERVAL=3000

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Optional: custom miner name for dashboard visibility
MINER_NAME=My-BLSR-Miner

###############################################
# Optional GPU Settings (if supported)
###############################################
# GPU_ENABLED=true
# GPU_PLATFORM=0
# GPU_DEVICE=0
# GPU_WORKSIZE=256
# GPU_LOCAL_WORKSIZE=64
