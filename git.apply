diff --git a/scripts/deploy.js b/scripts/deploy.js
new file mode 100644
index 0000000..d3f8a11
--- /dev/null
+++ b/scripts/deploy.js
@@ -0,0 +1,32 @@
+const hre = require("hardhat");
+
+async function main() {
+  const BitcoinSolar = await hre.ethers.getContractFactory("BitcoinSolar");
+  const token = await BitcoinSolar.deploy();
+
+  await token.waitForDeployment();
+
+  console.log("BitcoinSolar deployed to:", await token.getAddress());
+}
+
+main().catch((error) => {
+  console.error(error);
+  process.exitCode = 1;
+});
+
diff --git a/test/BitcoinSolar.test.js b/test/BitcoinSolar.test.js
new file mode 100644
index 0000000..e4c9b22
--- /dev/null
+++ b/test/BitcoinSolar.test.js
@@ -0,0 +1,45 @@
+const { expect } = require("chai");
+const { ethers } = require("hardhat");
+
+describe("BitcoinSolar", function () {
+  it("Deploys with correct name and symbol", async function () {
+    const Token = await ethers.getContractFactory("BitcoinSolar");
+    const token = await Token.deploy();
+
+    expect(await token.name()).to.equal("BitcoinSolar");
+    expect(await token.symbol()).to.equal("BTCSOL");
+  });
+
+  it("Mints full supply to deployer", async function () {
+    const [owner] = await ethers.getSigners();
+    const Token = await ethers.getContractFactory("BitcoinSolar");
+    const token = await Token.deploy();
+
+    const supply = await token.totalSupply();
+    const balance = await token.balanceOf(owner.address);
+
+    expect(balance).to.equal(supply);
+  });
+});
+
