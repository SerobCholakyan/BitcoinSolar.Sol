diff --git a/backend/app/miner/rewards.py b/backend/app/miner/rewards.py
new file mode 100644
index 0000000..aaa7777
--- /dev/null
+++ b/backend/app/miner/rewards.py
@@ -0,0 +1,72 @@
+import time
+from typing import Dict
+
+class RewardEngine:
+    def __init__(self):
+        self.balances: Dict[str, float] = {}
+        self.reward_rate = 0.0001  # BTCSOL per completed job
+
+    def credit(self, miner_id: str, job_id: str):
+        amount = self.reward_rate
+
+        if miner_id not in self.balances:
+            self.balances[miner_id] = 0.0
+
+        self.balances[miner_id] += amount
+
+        return {
+            "miner_id": miner_id,
+            "job_id": job_id,
+            "amount": amount,
+            "new_balance": self.balances[miner_id],
+            "timestamp": int(time.time())
+        }
+
+    def balance(self, miner_id: str):
+        return self.balances.get(miner_id, 0.0)
+
+    def all_balances(self):
+        return self.balances
+
+reward_engine = RewardEngine()
