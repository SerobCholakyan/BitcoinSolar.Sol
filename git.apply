--- /dev/null
+++ b/backend/app/blockchain.py
@@ -0,0 +1,62 @@
+import os
+from web3 import Web3
+from dotenv import load_dotenv
+
+load_dotenv()
+
+RPC_URL = os.getenv("MAINNET_RPC") or os.getenv("SEPOLIA_RPC")
+PRIVATE_KEY = os.getenv("PRIVATE_KEY")
+TOKEN_ADDRESS = os.getenv("BTCSOL_TOKEN_ADDRESS")
+
+with open("contracts/BitcoinSolar.json") as f:
+    ABI = f.read()
+
+w3 = Web3(Web3.HTTPProvider(RPC_URL))
+account = w3.eth.account.from_key(PRIVATE_KEY)
+
+def send_tokens(to, amount):
+    contract = w3.eth.contract(address=TOKEN_ADDRESS, abi=ABI)
+
+    tx = contract.functions.transfer(
+        to,
+        int(amount * 1e18)
+    ).build_transaction({
+        "from": account.address,
+        "nonce": w3.eth.get_transaction_count(account.address),
+        "gas": 200000,
+        "gasPrice": w3.eth.gas_price
+    diff --git a/backend/app/miner/settlement.py b/backend/app/miner/settlement.py
new file mode 100644
index 0000000..bbb9999
--- /dev/null
+++ b/backend/app/miner/settlement.py
@@ -0,0 +1,63 @@
+from typing import Dict
+from .rewards import reward_engine
+from app.blockchain import send_tokens
+
+class SettlementEngine:
+    def __init__(self):
+        self.pending: Dict[str, float] = {}
+
+    def request_withdrawal(self, miner_id: str, address: str):
+        balance = reward_engine.balance(miner_id)
+
+        if balance <= 0:
+            return None
+
+        self.pending[miner_id] = {
+            "address": address,
+            "amount": balance
+        }
+
+        reward_engine.balances[miner_id] = 0.0
+
+        return self.pending[miner_id]
+
+    def settle(self, miner_id: str):
+        if miner_id not in self.pending:
+            return None
+
+        entry = self.pending[miner_id]
+        tx_hash = send_tokens(entry["address"], entry["amount"])
+
+        del self.pending[miner_id]
+
+        return tx_hash
+
+settlement_engine = SettlementEngine()
})
+
+    signed = account.sign_transaction(tx)
+    tx_hash = w3.eth.send_raw_transaction(signed.rawTransaction)
+
+    return tx_hash.hex()
diff --git a/backend/app/miner/routes.py b/backend/app/miner/routes.py
index fed5555..ccc7777 100644
--- a/backend/app/miner/routes.py
+++ b/backend/app/miner/routes.py
@@ -2,6 +2,7 @@
 from .registry import registry
 from .jobs import job_engine
 from .rewards import reward_engine
+from .settlement import settlement_engine
 
 router = APIRouter(prefix="/miner", tags=["miner"])
 
@@ -60,3 +61,28 @@ async def balance(miner_id: str):
     return {"miner_id": miner_id, "balance": reward_engine.balance(miner_id)}
+
+
+@router.post("/claim/{miner_id}")
+async def claim(miner_id: str, payload: dict):
+    address = payload.get("address")
+    if not address:
+        return {"status": "error", "message": "Missing address"}
+
+    pending = settlement_engine.request_withdrawal(miner_id, address)
+    if not pending:
+        return {"status": "error", "message": "Nothing to claim"}
+
+    return {"status": "ok", "pending": pending}
+
+
+@router.post("/settle/{miner_id}")
+async def settle(miner_id: str):
+    tx = settlement_engine.settle(miner_id)
+    if not tx:
+        return {"status": "error", "message": "No pending withdrawal"}
+
+    return {"status": "ok", "tx_hash": tx}
