     if not updated:
         return {"status": "error", "message": "Invalid job_id"}
+
+    # Reward miner
+    miner_id = result.get("miner_id")
+    reward = reward_engine.credit(miner_id, job_id)
+
+    return {
+        "status": "ok",
+        "job": updated,
+        "reward": reward
+    }
+
+
+@router.get("/balance/{miner_id}")
