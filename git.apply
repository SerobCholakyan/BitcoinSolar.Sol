diff --git a/backend/app/miner/registry.py b/backend/app/miner/registry.py
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/backend/app/miner/registry.py
@@ -0,0 +1,52 @@
+import time
+from typing import Dict
+
+class MinerRegistry:
+    def __init__(self):
+        self.sessions: Dict[str, dict] = {}
+
+    def heartbeat(self, miner_id: str):
+        now = int(time.time())
+        if miner_id not in self.sessions:
+            self.sessions[miner_id] = {
+                "miner_id": miner_id,
+                "created_at": now,
+                "last_seen": now,
+                "active": True
+            }
+        else:
+            self.sessions[miner_id]["last_seen"] = now
+            self.sessions[miner_id]["active"] = True
+
+        return self.sessions[miner_id]
+
+    def get(self, miner_id: str):
+        return self.sessions.get(miner_id)
+
+    def all(self):
+        return list(self.sessions.values())
+
+registry = MinerRegistry()
diff --git a/backend/app/miner/routes.py b/backend/app/miner/routes.py
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/backend/app/miner/routes.py
@@ -0,0 +1,63 @@
+from fastapi import APIRouter
+from .registry import registry
+
+router = APIRouter(prefix="/miner", tags=["miner"])
+
+@router.get("/heartbeat/{miner_id}")
+async def heartbeat(miner_id: str):
+    session = registry.heartbeat(miner_id)
+    return {"status": "ok", "session": session}
+
+
+@router.get("/session/{miner_id}")
+async def session(miner_id: str):
+    data = registry.get(miner_id)
+    if not data:
+        return {"status": "not_found"}
+    return {"status": "ok", "session": data}
+
+
+@router.get("/sessions")
+async def sessions():
+    return {"miners": registry.all()}
+
+
+@router.get("/job/{miner_id}")
+async def job(miner_id: str):
+    # Placeholder for Patch 6 (actual mining jobs)
+    return {
+        "miner_id": miner_id,
+        "job": None,
+        "message": "No job assigned yet"
+    }
