diff --git a/miner/main.js b/miner/main.js
index b22c33d..f55a777 100644
--- a/miner/main.js
+++ b/miner/main.js
@@ -1,6 +1,7 @@
 const { app, BrowserWindow, ipcMain } = require("electron");
 const path = require("path");
 const axios = require("axios");
+const crypto = require("crypto");
 const { minerId, backendUrl } = require("./miner.config");
 
 let win;
@@ -52,6 +53,49 @@ async function heartbeatLoop() {
   setTimeout(heartbeatLoop, 5000);
 }
 
+
+// Miner job loop
+async function jobLoop() {
+  try {
+    const res = await axios.get(`${backendUrl}/miner/job/${minerId}`);
+    const job = res.data.job;
+
+    if (job) {
+      win.webContents.send("miner-job", job);
+
+      // Execute job
+      const payload = job.payload;
+      let result = null;
+
+      if (payload.type === "hash") {
+        result = crypto.createHash("sha256").update(payload.data).digest("hex");
+      }
+
+      // Submit result
+      await axios.post(`${backendUrl}/miner/result/${job.job_id}`, {
+        miner_id: minerId,
+        result
+      });
+
+      win.webContents.send("miner-job-complete", {
+        job_id: job.job_id,
+        result
+      });
+    }
+  } catch (err) {
+    win.webContents.send("miner-job-error", err.toString());
+  }
+
+  setTimeout(jobLoop, 4000);
+}
+
+
 app.whenReady().then(() => {
   heartbeatLoop();
+  jobLoop();
 });
