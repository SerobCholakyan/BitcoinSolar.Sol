diff --git a/backend/app/miner/jobs.py b/backend/app/miner/jobs.py
new file mode 100644
index 0000000..abc1111
--- /dev/null
+++ b/backend/app/miner/jobs.py
@@ -0,0 +1,78 @@
+import time
+import random
+from typing import Dict, Optional
+
+class JobEngine:
+    def __init__(self):
+        self.jobs: Dict[str, dict] = {}
+
+    def create_job(self, miner_id: str) -> dict:
+        job_id = f"job-{int(time.time())}-{random.randint(1000,9999)}"
+
+        job = {
+            "job_id": job_id,
+            "miner_id": miner_id,
+            "created_at": int(time.time()),
+            "payload": {
+                "type": "hash",
+                "data": f"solar-{random.randint(1, 999999)}"
+            },
+            "status": "assigned"
+        }
+
+        self.jobs[job_id] = job
+        return job
+
+    def get_job(self, miner_id: str) -> Optional[dict]:
+        # Always generate a new job for now
+        return self.create_job(miner_id)
+
+    def submit_result(self, job_id: str, result: dict):
+        if job_id not in self.jobs:
+            return None
+
+       
