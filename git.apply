--- /dev/null
+++ b/README.md
@@ -0,0 +1,32 @@
+# BitcoinSolar.Sol
+
+Canonical repository structure for the BitcoinSolar ecosystem.
+
+## Structure
+
+- contracts/ — Solidity smart contracts
+- scripts/ — Hardhat deployment scripts
+- test/ — Hardhat tests
+- backend/ — Python backend services
+- frontend/ — React/Next.js dashboard
+- miner/ — Electron desktop miner
+
+## Notes
+
+This is Patch 1/10: repository structure + cleanup.
+
+Next patches will add:
+- ERC20 contract
+- Hardhat config
+- Deployment scripts
+- Backend modules
+- Miner integration
+- Dashboard UI
diff --git a/contracts/BitcoinSolar.sol b/contracts/BitcoinSolar.sol
new file mode 100644
index 0000000..b1c3f11
--- /dev/null
+++ b/contracts/BitcoinSolar.sol
@@ -0,0 +1,62 @@
+// SPDX-License-Identifier: MIT
+pragma solidity ^0.8.20;
+
+import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
+
+/**
+ * @title BitcoinSolar (BTCSOL)
+ * @notice Fixed-supply ERC20 token with no owner, no minting, no admin functions.
+ * @dev Total supply: 21,000,000 BTCSOL (18 decimals)
+ */
+contract BitcoinSolar is ERC20 {
+    uint256 private constant INITIAL_SUPPLY = 21_000_000 * 1e18;
+
+    constructor() ERC20("BitcoinSolar", "BTCSOL") {
+        _mint(msg.sender, INITIAL_SUPPLY);
+    }
+}
+
