diff --git a/miner/main.js b/miner/main.js
new file mode 100644
index 0000000..b22c33d
--- /dev/null
+++ b/miner/main.js
@@ -0,0 +1,82 @@
+const { app, BrowserWindow, ipcMain } = require("electron");
+const path = require("path");
+const axios = require("axios");
+const { minerId, backendUrl } = require("./miner.config");
+
+let win;
+
+function createWindow() {
+  win = new BrowserWindow({
+    width: 900,
+    height: 600,
+    webPreferences: {
+      preload: path.join(__dirname, "preload.js"),
+      contextIsolation: true,
+      nodeIntegration: false
+    }
+  });
+
+  win.loadFile("renderer/index.html");
+}
+
+app.whenReady().then(() => {
+  createWindow();
+
+  app.on("activate", () => {
+    if (BrowserWindow.getAllWindows().length === 0) createWindow();
+  });
+});
+
+app.on("window-all-closed", () => {
+  if (process.platform !== "darwin") app.quit();
+});
+
+// Miner heartbeat loop
+async function heartbeatLoop() {
+  try {
+    await axios.get(`${backendUrl}/miner/heartbeat/${minerId}`);
+    win.webContents.send("miner-status", "online");
+  } catch (err) {
+    win.webContents.send("miner-status", "offline");
+  }
+
+  setTimeout(heartbeatLoop, 5000);
+}
+
+app.whenReady().then(() => {
+  heartbeatLoop();
+});
