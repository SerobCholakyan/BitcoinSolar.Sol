diff --git a/frontend/src/pages/Dashboard.jsx b/frontend/src/pages/Dashboard.jsx
new file mode 100644
index 0000000..f66a77b
--- /dev/null
+++ b/frontend/src/pages/Dashboard.jsx
@@ -0,0 +1,118 @@
+import React, { useEffect, useState } from "react";
+import axios from "axios";
+
+const API = "http://localhost:8000";
+
+export default function Dashboard() {
+  const [miners, setMiners] = useState([]);
+  const [balances, setBalances] = useState({});
+
+  async function loadMiners() {
+    const res = await axios.get(`${API}/miner/sessions`);
+    setMiners(res.data.miners);
+  }
+
+  async function loadBalances() {
+    const res = await axios.get(`${API}/balances`);
+    setBalances(res.data.balances);
+  }
+
+  useEffect(() => {
+    loadMiners();
+    loadBalances();
+    const interval = setInterval(() => {
+      loadMiners();
+      loadBalances();
+    }, 3000);
+    return () => clearInterval(interval);
+  }, []);
+
+  return (
+    <div style={{ padding: "40px" }}>
+      <h1>BitcoinSolar Dashboard</h1>
+
+      <h2>Active Miners</h2>
+      <table border="1" cellPadding="10" style={{ width: "100%", marginBottom: "40px" }}>
+        <thead>
+          <tr>
+            <th>Miner ID</th>
+            <th>Last Seen</th>
+            <th>Balance (BTCSOL)</th>
+          </tr>
+        </thead>
+        <tbody>
+          {miners.map((m) => (
+            <tr key={m.miner_id}>
+              <td>{m.miner_id}</td>
+              <td>{new Date(m.last_seen * 1000).toLocaleTimeString()}</td>
+              <td>{balances[m.miner_id] || 0}</td>
+            </tr>
+          ))}
+        </tbody>
+      </table>
+
+      <h2>Balances</h2>
+      <pre>{JSON.stringify(balances, null, 2)}</pre>
+    </div>
+  );
+}
