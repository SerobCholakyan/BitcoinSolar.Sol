# Polygon / RPC
POLYGON_RPC=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY

# Contract used by Flask backend (contracts/BitcoinSolar.sol)
CONTRACT_ADDRESS=0xYOUR_MINING_CONTRACT

# Backend signer (owner of the mining contract)
PRIVATE_KEY=0xyour_private_key_here

# Electron miner config
BLSR_RPC_URL=https://polygon-rpc.com
BLSR_CONTRACT_ADDRESS=0xYOUR_BLSR_CONTRACT
BLSR_PRIVATE_KEY=0xyour_private_key_here
BLSR_MINER_LOG_PATH=C:/miner/logs/miner.log
