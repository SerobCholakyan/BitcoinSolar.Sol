# Polygon / RPC
POLYGON_RPC=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY

# Contract used by Flask backend
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Backend signer (owner of the mining contract)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Electron miner config
BLSR_RPC_URL=https://polygon-rpc.com
BLSR_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
BLSR_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
BLSR_MINER_LOG_PATH=C:/miner/logs/miner.log
