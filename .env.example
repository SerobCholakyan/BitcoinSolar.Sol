# --------- Network ----------
# Infura Polygon Mainnet RPC (public project ID or your own)
POLYGON_RPC=https://polygon-mainnet.infura.io/v3/3f69ffd3c39747099f55586c0dfbe8ed

# --------- Contract ----------
# Replace this after deploying BitcoinSolar
CONTRACT_ADDRESS=0xYourContractAddressHere

# --------- Wallet ----------
# NEVER commit your real private key.
# Create a local ".env" file and put the real key there.
# Example (DO NOT USE THIS IN PRODUCTION):
# PRIVATE_KEY=0xabc123...
PRIVATE_KEY=your_private_wallet_key
