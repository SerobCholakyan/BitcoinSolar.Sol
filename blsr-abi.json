// -----------------------------------------------------------------------------
// Universal contract loader
// -----------------------------------------------------------------------------
export function getBlsrContract(providerOrSigner) {
  if (!providerOrSigner) {
    throw new Error("Provider or signer is required to initialize BLSR contract");
  }

  return new ethers.Contract(
    BLSR_ADDRESS,
    BLSR_ABI,
    providerOrSigner
  );
}
