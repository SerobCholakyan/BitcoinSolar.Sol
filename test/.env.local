############################################################
# BitcoinSolar Test Environment (.env.local)
############################################################

############################################################
# Test Network RPC Endpoints
############################################################
# Local Hardhat node or Anvil
RPC_LOCAL=http://127.0.0.1:8545

# Public testnets (safe for testing)
RPC_ETH_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
RPC_BLSR_TESTNET=https://blsr-rpc.bitcoinsolar.org

############################################################
# Chain IDs
############################################################
CHAIN_ID_LOCAL=31337
CHAIN_ID_SEPOLIA=11155111
CHAIN_ID_BLSR_TESTNET=12345

############################################################
# Test Wallets (DO NOT USE IN PRODUCTION)
############################################################
# Default Hardhat/Anvil test key
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional: second test account
TEST_PRIVATE_KEY_2=0x59c6995e998f97a5a0044966f094538c1f0f1f5b8f7f3c3c3c3c3c3c3c3c3c3

############################################################
# Contract Addresses (filled after deployment)
############################################################
BITCOINSOLAR_TOKEN_ADDRESS=
SUPPLY_MANAGER_ADDRESS=
SECURITY_BRIDGE_ADDRESS=

############################################################
# Orchestrator + Miner Backend (Test Mode)
############################################################
ORCHESTRATOR_URL=http://localhost:5050
MINER_BACKEND_URL=http://localhost:8080

# Shared test auth key
ORCHESTRATOR_AUTH_KEY=test-backend-auth-key

############################################################
# Testing Flags
############################################################
ENABLE_GAS_REPORTER=false
MOCK_ORCHESTRATOR=true
MOCK_MINER_BACKEND=true
MOCK_CHAIN=true
